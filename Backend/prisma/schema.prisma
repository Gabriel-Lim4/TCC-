                                                                                                                                                                                                            generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model usuarios {
  pk_id_usuario     Int                 @id @default(autoincrement())
  nome_usuario      String              @db.VarChar(100)
  email_usuario     String              @unique(map: "email_usuario") @db.VarChar(150)
  senha_hash        String              @db.VarChar(255)
  data_criacao_user DateTime?           @default(now()) @db.DateTime(0)
  analises          analises_ia[]
  contas            contas_vinculadas[]
}

model contas_vinculadas {
  pk_id_conta   Int                          @id @default(autoincrement())
  fk_id_usuario Int
  plataforma    contas_vinculadas_plataforma
  acess_token   String                       @db.Text
  account_id    String                       @db.VarChar(100)
  vinculado_em  DateTime?                    @default(now()) @db.DateTime(0)
  campanhas     campanhas[]
  usuario       usuarios                     @relation(fields: [fk_id_usuario], references: [pk_id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "contas_vinculadas_ibfk_1")

  @@index([fk_id_usuario], map: "fk_id_usuario")
}

model campanhas {
  pk_id_campanha  Int               @id @default(autoincrement())
  fk_id_conta     Int
  id_externo      String            @db.VarChar(100)
  nome_campanha   String            @db.VarChar(200)
  status_campanha String?           @db.VarChar(50)
  objetivo        String?           @db.VarChar(100)
  sincronizado_em DateTime?         @default(now()) @db.DateTime(0)
  analises        analises_ia[]
  conta           contas_vinculadas @relation(fields: [fk_id_conta], references: [pk_id_conta], onDelete: Cascade, onUpdate: NoAction, map: "campanhas_ibfk_1")
  metricas        metricas[]

  @@index([fk_id_conta], map: "fk_id_conta")
}

model metricas {
  pk_id_metrica   Int       @id @default(autoincrement())
  fk_id_campanha  Int
  tipo_metrica    String    @db.VarChar(100)
  valor_metrica   Decimal   @db.Decimal(15, 4)
  periodo_metrica DateTime  @db.Date
  coletado_em     DateTime? @default(now()) @db.DateTime(0)
  campanha        campanhas @relation(fields: [fk_id_campanha], references: [pk_id_campanha], onDelete: Cascade, onUpdate: NoAction, map: "metricas_ibfk_1")

  @@index([fk_id_campanha], map: "fk_id_campanha")
}

model analises_ia {
  pk_id_analise        Int       @id @default(autoincrement())
  fk_id_usuario        Int
  fk_id_campanha       Int
  texto_analise        String?   @db.Text
  sugestao_analise     String?   @db.Text
  data_geracao_analise DateTime? @default(now()) @db.DateTime(0)
  usuario              usuarios  @relation(fields: [fk_id_usuario], references: [pk_id_usuario], onDelete: Cascade, onUpdate: NoAction, map: "analises_ia_ibfk_1")
  campanha             campanhas @relation(fields: [fk_id_campanha], references: [pk_id_campanha], onDelete: Cascade, onUpdate: NoAction, map: "analises_ia_ibfk_2")

  @@index([fk_id_campanha], map: "fk_id_campanha")
  @@index([fk_id_usuario], map: "fk_id_usuario")
}

enum contas_vinculadas_plataforma {
  meta
  tiktok
}
